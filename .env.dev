# =============================================================================
# .env.dev — Local development environment variables
#
# This file is tracked in git because it contains only LOCAL, NON-SENSITIVE
# default credentials used exclusively in the developer docker-compose stack.
#
# NEVER use these values in a production or staging environment.
# Production secrets are managed via Docker Secrets (see secrets/ directory).
# =============================================================================

# MinIO local development credentials (non-sensitive, localhost only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
