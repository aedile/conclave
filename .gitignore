# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Node.js
# Audited P29-T29.2 (2026-03-18): frontend/node_modules/ is untracked (git ls-files returns 0).
# Air-gap note: if offline vendoring is ever required, migrate to `npm pack` tarballs
# rather than committing raw node_modules/. See ADR-0035 backlog item.
node_modules/
npm-debug.log
yarn-error.log

# Environment variables — production and local overrides
# .env.dev is intentionally tracked (contains non-sensitive local defaults only)
.env
.env.local
.env.production
.env.staging

# =============================================================================
# Conclave Engine — project-specific gitignored paths
# =============================================================================

# Real user data (PII) — NEVER commit
data/

# Generated synthetic datasets — NEVER commit
output/

# Application logs — NEVER commit
logs/
*.log

# Docker build artefacts
dist/
*.tar.gz

# Docker secrets — files exist on host, NEVER committed
# The secrets/ directory itself (with .gitkeep) IS tracked.
secrets/*.txt
secrets/*.key
secrets/*.pem
secrets/*.p12
secrets/*.pfx

# mTLS certificates — operator-provisioned, NEVER committed
# Generated by scripts/generate-mtls-certs.sh into secrets/mtls/.
# Only the directory is tracked (via secrets/mtls/.gitkeep if present).
secrets/mtls/*.crt
secrets/mtls/*.key
secrets/mtls/*.srl
# Rotation backups contain private key copies — NEVER commit (Finding 1: T46.3 review)
secrets/mtls/backup-*/

# pgbouncer credentials — plaintext password file MUST NOT be committed.
# Operators must copy pgbouncer/userlist.txt.example to pgbouncer/userlist.txt
# and populate it with a SCRAM-SHA-256 hashed password before deploying.
pgbouncer/userlist.txt

# CI-generated artefacts — NEVER commit
sbom.json

# pytest coverage data — regenerated every test run
.coverage

# Agent worktree clones — transient, disk-heavy
.clone/
.claude/worktrees/

# pytest-hypothesis cache — regenerated every test run
.hypothesis/

# pytest coverage temp files
.coverage.*

# mutmut mutation testing cache — regenerated every test run
.mutmut-cache

# mutmut mutation testing sandbox — regenerated every run
mutants/

# =============================================================================
# Demo generated outputs (T52.1)
# =============================================================================
# Generated PNG and PDF figures — large binaries, regenerated from source
demos/results/*.csv
demos/results/*.json
demos/figures/*.png
demos/figures/*.pdf
# Allow committed SVG figures (small, diff-friendly) and versioned JSON artifacts
!demos/figures/*.svg
!demos/results/*_v1.json
!demos/results/grid_config.json
