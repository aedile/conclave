# .env.example
#
# Template for environment variables used by this project.
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Variables marked [AUTO] are written automatically by
# .claude/hooks/worktree_create.sh when a Git Worktree is created.
# You do not need to set them manually during local development.
# Override them here if you need non-default values.

# ---------------------------------------------------------------------------
# Application-Level Encryption (ALE) — Task 2.2
#
# ALE_KEY must be a valid Fernet key (URL-safe base64-encoded 32 bytes).
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# NEVER commit a real ALE_KEY to VCS.  In production, inject this value
# via a secrets manager (HashiCorp Vault, AWS Secrets Manager, Docker secrets).
# ---------------------------------------------------------------------------
ALE_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# ---------------------------------------------------------------------------
# Database connection URLs — Task 2.2
#
# DATABASE_URL: direct connection to PostgreSQL (used by Alembic migrations
#   and integration tests).
# PGBOUNCER_URL: connection via PgBouncer transaction pool (used by the
#   application at runtime for reduced connection overhead).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://synth_user:synth_dev_password@localhost:5432/synth_engine  # pragma: allowlist secret
PGBOUNCER_URL=postgresql://synth_user:synth_dev_password@localhost:6432/synth_engine  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# Database credentials (used by worktree_create.sh when generating .env.local)
# ---------------------------------------------------------------------------

# PostgreSQL test user for isolated worktree databases.
# Overrides the default 'postgres' value written to each worktree's .env.local.
PG_TEST_USER=postgres

# PostgreSQL test password for isolated worktree databases.
# Overrides the default 'postgres' value written to each worktree's .env.local.
PG_TEST_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Vault — Task 2.4
#
# VAULT_SEAL_SALT: base64url-encoded 16-byte value used as PBKDF2 salt for
#   KEK derivation.  Not secret — but must remain consistent across restarts
#   so the same passphrase always produces the same KEK.
# Generate: python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(16)).decode())"
#
# AUDIT_KEY: hex-encoded 32-byte HMAC key for signing audit events.
#   SECRET — treat like ALE_KEY; never commit a real value.
# Generate: python3 -c "import os; print(os.urandom(32).hex())"
# ---------------------------------------------------------------------------
VAULT_SEAL_SALT=
AUDIT_KEY=  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# Masking Salt — Task 3.5.4 / Phase 4 (ADV-035)
#
# MASKING_SALT: deterministic salt for format-preserving masking. In
#   production, inject from Vault or environment. If unset, bootstrapper/cli.py
#   falls back to a hardcoded development value and logs a warning.
#
# NEVER commit a real MASKING_SALT to VCS.  In production, inject via
# HashiCorp Vault or Docker secrets.
# ---------------------------------------------------------------------------
# MASKING_SALT=<inject-from-vault-in-production>

# ---------------------------------------------------------------------------
# MinIO Ephemeral Storage — Task 4.1 / Task 4.2b (ADV-039)
#
# These credentials are read from Docker secrets at /run/secrets/ in
# production. For local development without Docker secrets, set them here.
#
# MINIO_EPHEMERAL_ACCESS_KEY / MINIO_EPHEMERAL_SECRET_KEY:
#   MinIO credentials for the ephemeral synthesis artifact bucket.
#   Correspond to Docker secrets minio_ephemeral_access_key /
#   minio_ephemeral_secret_key read by bootstrapper/main.py.
# MINIO_ENDPOINT: MinIO server URL (default: http://minio:9000 in Docker Compose).
# ---------------------------------------------------------------------------
# MINIO_EPHEMERAL_ACCESS_KEY=minioadmin
# MINIO_EPHEMERAL_SECRET_KEY=minioadmin  # pragma: allowlist secret
# MINIO_ENDPOINT=http://localhost:9000

# ---------------------------------------------------------------------------
# Huey Task Queue — Task 4.2c (ADV-043)
#
# HUEY_BACKEND: "redis" (default for production) or "memory" (for tests /
#   local dev without a Redis instance). Selects the Huey storage backend
#   used by shared/task_queue.py.
# REDIS_URL: Redis connection URL. Only used when HUEY_BACKEND=redis.
#   Auth credentials in this URL are masked before logging.
# HUEY_IMMEDIATE: "true" to execute tasks synchronously in the calling
#   process (useful for integration tests and local debugging).
# ---------------------------------------------------------------------------
# HUEY_BACKEND=redis
# REDIS_URL=redis://redis:6379/0
# HUEY_IMMEDIATE=false

# ---------------------------------------------------------------------------
# Synthesis Hardware — Phase 4 (ADV-070)
#
# FORCE_CPU: When set to "true", forces the synthesis training pipeline to run
#   on CPU only, disabling all GPU/CUDA acceleration. This is useful in
#   environments without a compatible NVIDIA GPU (e.g., CI runners, air-gapped
#   servers with no GPU, or macOS development machines). When unset or "false",
#   the synthesizer auto-detects available CUDA devices and uses the first
#   available GPU.
#
# Set to "true" in any deployment environment where GPU hardware is absent or
# unreliable. No action required on GPU-equipped hosts — auto-detection handles
# device selection automatically.
# ---------------------------------------------------------------------------
# FORCE_CPU=false

# ---------------------------------------------------------------------------
# Model Artifact Signing — Phase 8 (ADV-040)
#
# ARTIFACT_SIGNING_KEY: hex-encoded HMAC-SHA256 key for signing model artifacts.
#   Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
#   Required when ModelArtifact signing is enabled. Omit for unsigned artifacts.
#
# When set, decode with bytes.fromhex(os.environ["ARTIFACT_SIGNING_KEY"]) and
# pass to ModelArtifact.save() / ModelArtifact.load() as the signing_key argument.
#
# In production, inject via a secrets manager (HashiCorp Vault, Docker secrets,
# or a Kubernetes Secret). NEVER commit a real key here.
# ---------------------------------------------------------------------------
# ARTIFACT_SIGNING_KEY=

# ---------------------------------------------------------------------------
# License Activation — Task 5.2
#
# LICENSE_PUBLIC_KEY: PEM-encoded RSA public key for verifying license JWTs
#   signed by the central licensing server.
#
# When set, overrides the embedded placeholder key at runtime (for key
# rotation without redeployment).  Must be the full PEM string including
# the -----BEGIN PUBLIC KEY----- and -----END PUBLIC KEY----- delimiters,
# with newlines replaced by \n if passed as a single-line env var.
#
# In production, inject via a secrets manager (HashiCorp Vault, Docker
# secrets, or a Kubernetes Secret).  NEVER commit a real key here.
#
# If unset, the embedded placeholder key is used.  This placeholder cannot
# validate any real license JWT because its corresponding private key is
# not distributed.  Production deployments MUST set this variable.
# ---------------------------------------------------------------------------
# LICENSE_PUBLIC_KEY=<PEM-encoded RSA public key from the licensing server>

# ---------------------------------------------------------------------------
# Worktree port assignments [AUTO — do not set manually]
# These are written by .claude/hooks/worktree_create.sh
# ---------------------------------------------------------------------------

# PORT_APP=3000       # Main application server port
# PORT_API=3001       # API server port
# PORT_DB=3002        # Database port
# PORT_TEST=3003      # Test runner port
# PORT_METRICS=3004   # Metrics/observability port

# Convenience URL aliases [AUTO]
# APP_URL=http://localhost:3000
# API_URL=http://localhost:3001
# DATABASE_URL=postgresql://postgres:postgres@localhost:3002/conclave_test  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# ChromaDB (semantic memory)
# ---------------------------------------------------------------------------

# Path to local ChromaDB storage. Defaults to ~/.chroma_data if unset.
# CHROMA_DATA_PATH=~/.chroma_data

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------

# HMAC secret for signing access tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit a real value here.
# JWT_SECRET_KEY=<generate-with-command-above>

# ---------------------------------------------------------------------------
# Deployment Mode — Startup Config Validation
#
# ENV or CONCLAVE_ENV: set to "production" to enable strict startup
#   validation (e.g., ARTIFACT_SIGNING_KEY becomes required). Both
#   variable names are checked for compatibility with deployment tooling.
#   If neither is set, the application runs in development mode with
#   relaxed validation.
#
# See: src/synth_engine/bootstrapper/config_validation.py
# ---------------------------------------------------------------------------
# ENV=production
# CONCLAVE_ENV=production
