# .env.example
#
# Template for environment variables used by this project.
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Variables marked [AUTO] are written automatically by
# .claude/hooks/worktree_create.sh when a Git Worktree is created.
# You do not need to set them manually during local development.
# Override them here if you need non-default values.

# ---------------------------------------------------------------------------
# Application-Level Encryption (ALE) — Task 2.2
#
# ALE_KEY must be a valid Fernet key (URL-safe base64-encoded 32 bytes).
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# NEVER commit a real ALE_KEY to VCS.  In production, inject this value
# via a secrets manager (HashiCorp Vault, AWS Secrets Manager, Docker secrets).
# ---------------------------------------------------------------------------
ALE_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# ---------------------------------------------------------------------------
# Database connection URLs — Task 2.2
#
# DATABASE_URL: direct connection to PostgreSQL (used by Alembic migrations
#   and integration tests).
# PGBOUNCER_URL: connection via PgBouncer transaction pool (used by the
#   application at runtime for reduced connection overhead).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://synth_user:synth_dev_password@localhost:5432/synth_engine  # pragma: allowlist secret
PGBOUNCER_URL=postgresql://synth_user:synth_dev_password@localhost:6432/synth_engine  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# Database credentials (used by worktree_create.sh when generating .env.local)
# ---------------------------------------------------------------------------

# PostgreSQL test user for isolated worktree databases.
# Overrides the default 'postgres' value written to each worktree's .env.local.
PG_TEST_USER=postgres

# PostgreSQL test password for isolated worktree databases.
# Overrides the default 'postgres' value written to each worktree's .env.local.
PG_TEST_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Vault — Task 2.4
#
# VAULT_SEAL_SALT: base64url-encoded 16-byte value used as PBKDF2 salt for
#   KEK derivation.  Not secret — but must remain consistent across restarts
#   so the same passphrase always produces the same KEK.
# Generate: python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(16)).decode())"
#
# AUDIT_KEY: hex-encoded 32-byte HMAC key for signing audit events.
#   SECRET — treat like ALE_KEY; never commit a real value.
# Generate: python3 -c "import os; print(os.urandom(32).hex())"
# ---------------------------------------------------------------------------
VAULT_SEAL_SALT=
AUDIT_KEY=  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# Masking Salt — Task 3.5.4 / Phase 4 (ADV-035)
#
# MASKING_SALT: deterministic salt for format-preserving masking. In
#   production, inject from Vault or environment. If unset, bootstrapper/cli.py
#   falls back to a hardcoded development value and logs a warning.
#
# NEVER commit a real MASKING_SALT to VCS.  In production, inject via
# HashiCorp Vault or Docker secrets.
# ---------------------------------------------------------------------------
# MASKING_SALT=<inject-from-vault-in-production>

# ---------------------------------------------------------------------------
# MinIO Ephemeral Storage — Task 4.1 / Task 4.2b (ADV-039)
#
# These credentials are read from Docker secrets at /run/secrets/ in
# production. For local development without Docker secrets, set them here.
#
# MINIO_EPHEMERAL_ACCESS_KEY / MINIO_EPHEMERAL_SECRET_KEY:
#   MinIO credentials for the ephemeral synthesis artifact bucket.
#   Correspond to Docker secrets minio_ephemeral_access_key /
#   minio_ephemeral_secret_key read by bootstrapper/main.py.
# MINIO_ENDPOINT: MinIO server URL (default: http://minio:9000 in Docker Compose).
# ---------------------------------------------------------------------------
# MINIO_EPHEMERAL_ACCESS_KEY=minioadmin
# MINIO_EPHEMERAL_SECRET_KEY=minioadmin  # pragma: allowlist secret
# MINIO_ENDPOINT=http://localhost:9000

# ---------------------------------------------------------------------------
# Huey Task Queue — Task 4.2c (ADV-043)
#
# HUEY_BACKEND: "redis" (default for production) or "memory" (for tests /
#   local dev without a Redis instance). Selects the Huey storage backend
#   used by shared/task_queue.py.
# REDIS_URL: Redis connection URL. Only used when HUEY_BACKEND=redis.
#   Auth credentials in this URL are masked before logging.
# HUEY_IMMEDIATE: "true" to execute tasks synchronously in the calling
#   process (useful for integration tests and local debugging).
# ---------------------------------------------------------------------------
# HUEY_BACKEND=redis
# REDIS_URL=redis://redis:6379/0
# HUEY_IMMEDIATE=false

# ---------------------------------------------------------------------------
# Synthesis Hardware — Phase 4 (ADV-070)
#
# FORCE_CPU: When set to "true", forces the synthesis training pipeline to run
#   on CPU only, disabling all GPU/CUDA acceleration. This is useful in
#   environments without a compatible NVIDIA GPU (e.g., CI runners, air-gapped
#   servers with no GPU, or macOS development machines). When unset or "false",
#   the synthesizer auto-detects available CUDA devices and uses the first
#   available GPU.
#
# Set to "true" in any deployment environment where GPU hardware is absent or
# unreliable. No action required on GPU-equipped hosts — auto-detection handles
# device selection automatically.
# ---------------------------------------------------------------------------
# FORCE_CPU=false

# ---------------------------------------------------------------------------
# Model Artifact Signing — Phase 8 (ADV-040) / T42.1
#
# ARTIFACT_SIGNING_KEY: hex-encoded HMAC-SHA256 key for signing model artifacts.
#   Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
#   Required when ModelArtifact signing is enabled. Omit for unsigned artifacts.
#
# When set, decode with bytes.fromhex(os.environ["ARTIFACT_SIGNING_KEY"]) and
# pass to ModelArtifact.save() / ModelArtifact.load() as the signing_key argument.
#
# In production, inject via a secrets manager (HashiCorp Vault, Docker secrets,
# or a Kubernetes Secret). NEVER commit a real key here.
# ---------------------------------------------------------------------------
# ARTIFACT_SIGNING_KEY=

# Multi-key rotation support (T42.1). When set, takes precedence over ARTIFACT_SIGNING_KEY.
# ARTIFACT_SIGNING_KEYS: JSON dict of hex key ID → hex key.
# ARTIFACT_SIGNING_KEYS={"00000001": "<64-hex-char-key>"}
# ARTIFACT_SIGNING_KEY_ACTIVE: hex key ID of the active signing key.
# ARTIFACT_SIGNING_KEY_ACTIVE=00000001

# ---------------------------------------------------------------------------
# License Activation — Task 5.2
#
# LICENSE_PUBLIC_KEY: PEM-encoded RSA public key for verifying license JWTs
#   signed by the central licensing server.
#
# When set, overrides the embedded placeholder key at runtime (for key
# rotation without redeployment).  Must be the full PEM string including
# the -----BEGIN PUBLIC KEY----- and -----END PUBLIC KEY----- delimiters,
# with newlines replaced by \n if passed as a single-line env var.
#
# In production, inject via a secrets manager (HashiCorp Vault, Docker
# secrets, or a Kubernetes Secret).  NEVER commit a real key here.
#
# If unset, the embedded placeholder key is used.  This placeholder cannot
# validate any real license JWT because its corresponding private key is
# not distributed.  Production deployments MUST set this variable.
# ---------------------------------------------------------------------------
# LICENSE_PUBLIC_KEY=<PEM-encoded RSA public key from the licensing server>

# ---------------------------------------------------------------------------
# Worktree port assignments [AUTO — do not set manually]
# These are written by .claude/hooks/worktree_create.sh
# ---------------------------------------------------------------------------

# PORT_APP=3000       # Main application server port
# PORT_API=3001       # API server port
# PORT_DB=3002        # Database port
# PORT_TEST=3003      # Test runner port
# PORT_METRICS=3004   # Metrics/observability port

# Convenience URL aliases [AUTO]
# APP_URL=http://localhost:3000
# API_URL=http://localhost:3001
# DATABASE_URL=postgresql://postgres:postgres@localhost:3002/conclave_test  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# JWT Authentication — Task T39.1
# ---------------------------------------------------------------------------

# HMAC secret for signing access tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit a real value here.
# JWT_SECRET_KEY=<generate-with-command-above>

# Bcrypt hash of the operator passphrase. Required when JWT_SECRET_KEY is set.
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your-passphrase', bcrypt.gensalt()).decode())"
# In production, inject from a secrets manager (HashiCorp Vault, Docker secrets).
# NEVER commit a real hash here.
# OPERATOR_CREDENTIALS_HASH=<generate-with-command-above>

# JWT signing algorithm. Default: HS256.
# Only HS256 is supported in the current single-operator model.
# JWT_ALGORITHM=HS256

# Lifetime of issued access tokens in seconds. Default: 3600 (1 hour).
# Reduce for stricter session management in high-security deployments.
# JWT_EXPIRY_SECONDS=3600

# ---------------------------------------------------------------------------
# T63.2 — CONCLAVE_ prefixed env var aliases
#
# Four security-critical env vars have CONCLAVE_-prefixed aliases that are
# now the preferred naming convention.  Both old and new names are accepted
# for backward compatibility.  The CONCLAVE_ variant takes precedence when
# both are set.
#
# CONCLAVE_DATABASE_URL  — preferred alias for DATABASE_URL
# CONCLAVE_AUDIT_KEY     — preferred alias for AUDIT_KEY
# CONCLAVE_MASKING_SALT  — preferred alias for MASKING_SALT
# CONCLAVE_JWT_SECRET_KEY — preferred alias for JWT_SECRET_KEY
#
# See docs/adr/ADR-0060-conclave-env-var-naming.md for the naming
# convention rationale and migration guidance.
# ---------------------------------------------------------------------------
# CONCLAVE_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db  # pragma: allowlist secret
# CONCLAVE_AUDIT_KEY=<hex-encoded 32-byte key>  # pragma: allowlist secret
# CONCLAVE_MASKING_SALT=<secret salt>  # pragma: allowlist secret
# CONCLAVE_JWT_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">  # pragma: allowlist secret

# ---------------------------------------------------------------------------
# Deployment Mode — Startup Config Validation
#
# ENV or CONCLAVE_ENV: set to "production" to enable strict startup
#   validation (e.g., ARTIFACT_SIGNING_KEY becomes required). Both
#   variable names are checked for compatibility with deployment tooling.
#   If neither is set, the application runs in development mode with
#   relaxed validation.
#
# See: src/synth_engine/bootstrapper/config_validation.py
# ---------------------------------------------------------------------------
# ENV=production  # [DEPRECATED] — use CONCLAVE_ENV= instead
CONCLAVE_ENV=production

# ---------------------------------------------------------------------------
# SSL enforcement override — ingestion validator (ADV-020 / T20.4)
# CONCLAVE_SSL_REQUIRED: When "false", sslmode=require is not enforced for
#   non-loopback hosts. ONLY for Docker bridge networks.
#   Default (unset or "true"): sslmode=require mandatory for production.
# ---------------------------------------------------------------------------
# CONCLAVE_SSL_REQUIRED=false

# ---------------------------------------------------------------------------
# Parquet Path Sandbox — T69.7 (ADV-P68-02)
#
# CONCLAVE_DATA_DIR: Base directory that parquet_path values in POST /jobs
#   must resolve inside.  Prevents path traversal attacks where an attacker
#   supplies a path to a world-readable .parquet file outside the data dir.
#
#   Defaults to 'data/' (resolved to absolute at startup).
#   In production mode, the directory MUST exist at startup.
#   Set to a specific absolute path in production (e.g. /app/data).
#   Forbidden value: '/' (filesystem root — defeats the sandbox).
# ---------------------------------------------------------------------------
# CONCLAVE_DATA_DIR=data/

# ---------------------------------------------------------------------------
# TLS certificate path — T42.2 HTTPS enforcement startup check
#
# CONCLAVE_TLS_CERT_PATH: Path to TLS certificate used by the reverse proxy.
# When set, suppresses the TLS misconfiguration startup warning.
# Leave blank if TLS is terminated externally without a local cert path.
# CONCLAVE_TLS_CERT_PATH=

# ---------------------------------------------------------------------------
# Observability — OpenTelemetry OTLP Exporter (optional)
#
# OTEL_EXPORTER_OTLP_ENDPOINT: gRPC endpoint for an OpenTelemetry collector
#   that receives distributed traces from the Conclave Engine.
#
#   When set, traces are forwarded to the specified collector via the
#   opentelemetry-exporter-otlp package (must be installed separately).
#   When absent, an in-memory exporter is used — suitable for development
#   and testing only; no spans leave the process.
#
#   Typical values:
#     http://otel-collector:4317   (gRPC)
#     http://localhost:4317        (local collector)
#
#   Requires: poetry add opentelemetry-exporter-otlp
#   See: src/synth_engine/shared/telemetry.py
# ---------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ---------------------------------------------------------------------------
# Privacy Budget — Phase 22 (P22-T22.3)
#
# PRIVACY_BUDGET_EPSILON: Total epsilon budget for differential privacy
#   training jobs.  The PrivacyLedger (seeded by migration 005) is
#   initialised with this value.  When unset, the migration default is used
#   (100.0 epsilon units).  In production, set a value appropriate for your
#   privacy requirements (lower = stronger privacy guarantee).
#
# See: modules/privacy/accountant.py and alembic/versions/*005*.py
# ---------------------------------------------------------------------------
# PRIVACY_BUDGET_EPSILON=100.0

# ---------------------------------------------------------------------------
# E2E Load Test — optional / dev-only
#
# These variables are consumed by the E2E load test CLI (tests/e2e/) via
# Click envvar= bindings.  All are optional: the script defaults shown below
# are suitable for the standard docker-compose.cpu.yml stack running locally.
# Do NOT set these in production deployments.
#
# SOURCE_DSN: PostgreSQL DSN for the source database used to seed load test
#   data.  The load test script connects directly (bypassing PgBouncer) to
#   insert rows at high throughput.
# TARGET_DSN: PostgreSQL DSN for the target (synthesised output) database.
# API_BASE_URL: Base URL for the Conclave Engine REST API.
# VAULT_PASSPHRASE: Vault unseal passphrase for the dev stack.
#   NEVER use a real production passphrase here.
# LICENSE_KEY_PATH: Filesystem path to the RSA private key used to sign
#   development license JWTs during E2E runs.
#
# LICENSE_PUBLIC_KEY escaping note:
#   When LICENSE_PUBLIC_KEY is injected via Docker env_file (as in
#   docker-compose.cpu.yml), PEM newlines must be encoded as literal \n
#   characters on a single line.  The application converts them back to
#   real newlines at runtime via:
#     value.replace("\\n", "\n")
#   Example single-line form:
#     LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----
# ---------------------------------------------------------------------------
# SOURCE_DSN=postgresql://conclave:conclave@localhost:5432/conclave_source  # pragma: allowlist secret
# TARGET_DSN=postgresql://conclave:conclave@localhost:5432/conclave_target  # pragma: allowlist secret
# API_BASE_URL=http://localhost:8000
# VAULT_PASSPHRASE=test-passphrase  # pragma: allowlist secret
# LICENSE_KEY_PATH=secrets/license_dev_private_key.pem

# ---------------------------------------------------------------------------
# Rate Limiting — Task T39.3
#
# Per-endpoint request rate limits (requests per minute). The middleware
# uses FixedWindowRateLimiter with MemoryStorage — no external dependencies.
# Limits reset on process restart.
#
# RATE_LIMIT_UNSEAL_PER_MINUTE: Per-IP limit on /unseal (vault unseal).
#   Default: 5. Protects against brute-force attacks before authentication
#   is available. Raise only with explicit security review.
#
# RATE_LIMIT_AUTH_PER_MINUTE: Per-IP limit on /auth/token (credential
#   stuffing protection). Default: 10.
#
# RATE_LIMIT_GENERAL_PER_MINUTE: Per-operator limit on all other endpoints.
#   Default: 60.
#
# RATE_LIMIT_DOWNLOAD_PER_MINUTE: Per-operator limit on /jobs/{id}/download
#   (bandwidth protection). Default: 10.
#
# CONCLAVE_RATE_LIMIT_FAIL_OPEN: When "true", restores pre-P63 fail-open
#   behavior on Redis failure: requests are allowed through via in-memory
#   fallback (within in-memory limits). Default: false (fail-closed).
#   WARNING: enabling fail-open in production allows brute-force and DoS
#   attacks to bypass distributed rate limits during Redis outages.
#   Only use in non-production environments. A security WARNING is logged
#   at startup when true in production (T63.3).
# ---------------------------------------------------------------------------
# RATE_LIMIT_UNSEAL_PER_MINUTE=5
# RATE_LIMIT_AUTH_PER_MINUTE=10
# RATE_LIMIT_GENERAL_PER_MINUTE=60
# RATE_LIMIT_DOWNLOAD_PER_MINUTE=10
# CONCLAVE_RATE_LIMIT_FAIL_OPEN=false
#
# CONCLAVE_TRUSTED_PROXY_COUNT: Number of trusted reverse-proxy hops in front
#   of the application. Used when extracting the real client IP from
#   X-Forwarded-For for per-IP rate limiting. Zero-trust default: 0 (disabled —
#   X-Forwarded-For is ignored and the connecting socket IP is used directly).
#   Set to 1 if a single reverse proxy (nginx, Caddy) terminates TLS in front
#   of the app. Set to N for N chained proxies. Never set higher than the
#   actual number of trusted proxies in your deployment — over-trusting allows
#   clients to spoof their IP address and bypass per-IP rate limits.
#   Default: 0.
# CONCLAVE_TRUSTED_PROXY_COUNT=0
#
# CONCLAVE_HEALTH_STRICT: Controls /ready endpoint strictness.
#   true  — /ready returns 503 for any unreachable or unconfigured service
#   false — unconfigured services are skipped (permissive)
#   unset — auto-detected: true in production, false in development
# CONCLAVE_HEALTH_STRICT=
# ---------------------------------------------------------------------------
# Data Retention Policy — Task T41.1 (GDPR/CCPA Compliance)
#
# JOB_RETENTION_DAYS: Days to retain synthesis_job records before deletion.
#   Jobs with legal_hold=True are exempt regardless of TTL.  Default: 90.
#
# AUDIT_RETENTION_DAYS: Days to retain audit events before archival to cold
#   storage.  Audit events are NEVER deleted — only archived.
#   Default: 1095 (3 years, GDPR minimum).
#   Use 2555 (7 years) for financial-services / SOX deployments.
#
# ARTIFACT_RETENTION_DAYS: Days to retain generated Parquet artifact files.
#   Default: 30 days.
# ---------------------------------------------------------------------------
# JOB_RETENTION_DAYS=90
# AUDIT_RETENTION_DAYS=1095
# ARTIFACT_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Idempotency (T45.1)
#
# IDEMPOTENCY_TTL_SECONDS: Time-to-live in seconds for idempotency keys in
#   Redis. Duplicate POST/PUT/PATCH/DELETE requests carrying the same
#   Idempotency-Key header within this window are rejected with HTTP 409.
#   Default: 300 (5 minutes).
# ---------------------------------------------------------------------------
# IDEMPOTENCY_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# Orphan Task Reaper (T45.2)
#
# REAPER_STALE_THRESHOLD_MINUTES: Number of minutes after which an
#   IN_PROGRESS synthesis job is considered orphaned and will be marked FAILED
#   by the periodic reaper task. Must be >= 5.
#   Default: 60 (1 hour).
# ---------------------------------------------------------------------------
# REAPER_STALE_THRESHOLD_MINUTES=60

# ---------------------------------------------------------------------------
# Webhooks (T45.3)
#
# WEBHOOK_MAX_REGISTRATIONS: Maximum number of active webhook registrations
#   per operator. Enforced at POST /webhooks time.
#   Default: 10.
#
# WEBHOOK_DELIVERY_TIMEOUT_SECONDS: HTTP timeout in seconds for each webhook
#   delivery attempt. Applied per attempt; up to 3x total for 3 retries.
#   Default: 10.
# ---------------------------------------------------------------------------
# WEBHOOK_MAX_REGISTRATIONS=10
# WEBHOOK_DELIVERY_TIMEOUT_SECONDS=10
#
# WEBHOOK_CIRCUIT_BREAKER_THRESHOLD: Number of consecutive delivery failures
#   before the circuit breaker trips for a callback URL. While the circuit is
#   open, deliveries to that URL are skipped (status=SKIPPED) until the
#   cooldown expires. Default: 3.
#
# WEBHOOK_CIRCUIT_BREAKER_COOLDOWN_SECONDS: Duration in seconds that the
#   circuit breaker stays open (blocking deliveries) after tripping. After
#   this period, one probe delivery is attempted; success resets the circuit,
#   failure re-trips it. Default: 300 (5 minutes).
# WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=3
# WEBHOOK_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# ---------------------------------------------------------------------------
# mTLS Inter-Container Communication (T46.2)
#
# Set MTLS_ENABLED=true to activate mutual TLS on all container-to-container
# data-plane connections (app→PgBouncer, PgBouncer→PostgreSQL, app→Redis).
# Requires certificates generated by scripts/generate-mtls-certs.sh (T46.1)
# and the docker-compose.mtls.yml overlay.
#
# When MTLS_ENABLED=false (default), containers communicate over the Docker
# bridge network without TLS — acceptable for single-host deployments where
# the bridge network provides equivalent isolation.
#
# In production or multi-host deployments, set MTLS_ENABLED=true and inject
# cert paths via a secrets manager (HashiCorp Vault, Docker secrets).
# NEVER commit real certificate paths or cert material to VCS.
# ---------------------------------------------------------------------------
# MTLS_ENABLED=false
# MTLS_CA_CERT_PATH=secrets/mtls/ca.crt
# MTLS_CLIENT_CERT_PATH=secrets/mtls/app.crt
# MTLS_CLIENT_KEY_PATH=secrets/mtls/app.key

# ---------------------------------------------------------------------------
# Parquet Memory Bounds — T47.7
# ---------------------------------------------------------------------------
# PARQUET_MAX_FILE_BYTES=2147483648
# PARQUET_MAX_ROWS=10000000

# ---------------------------------------------------------------------------
# Audit Trail Anchoring (T48.4)
#
# ANCHOR_BACKEND: Backend for publishing audit chain anchors.
#   "local_file"   — appends JSON lines to a local file (development / air-gapped).
#                    WARNING: provides no external attestation; a compromised
#                    host can rewrite the file.
#   "s3_object_lock" — writes to an S3 Object Lock bucket (production).
#                    Object Lock (COMPLIANCE mode) prevents any modification or
#                    deletion of anchors, even by the bucket owner.
#
# ANCHOR_FILE_PATH: Path to the anchor JSONL file (local_file backend only).
#   Default: logs/audit_anchors.jsonl
#
# ANCHOR_EVERY_N_EVENTS: Publish an anchor every N audit events.
#   Default: 1000.  Lower values increase durability but add I/O overhead.
#
# ANCHOR_EVERY_SECONDS: Publish an anchor at least once per this many seconds
#   (time-based trigger independent of event count).
#   Default: 86400 (24 hours).
# ---------------------------------------------------------------------------
# ANCHOR_BACKEND=local_file              # or s3_object_lock for production
# ANCHOR_FILE_PATH=logs/audit_anchors.jsonl
# ANCHOR_EVERY_N_EVENTS=1000
# ANCHOR_EVERY_SECONDS=86400
